# Byte-compiled / cache
__pycache__/
*.py[cod]
*.egg-info/
.mypy_cache/
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Data (large, regenerable via preprocessing pipeline)
data/raw/*
data/processed/*
data/train/*
data/val/*
data/test/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/train/.gitkeep
!data/val/.gitkeep
!data/test/.gitkeep

# Models & logs
saved_models/*.keras
saved_models/*.pkl
logs/
outputs/*.png
outputs/reports/*

# Streamlit / OS / IDE
.streamlit/
.DS_Store
.idea/
.vscode/

# Downloaded archives
*.rar
*.zip
